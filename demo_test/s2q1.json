                "statementHandle": "01c3d78f-0812-9dd0-0053-fc07168fa6e6"
              },
              "result_set_truncated": false,
              "sql": "WITH __channel_financial AS (\n  SELECT\n    channel_group,\n    clv_tier,\n    guest_id,\n    order_channel,\n    transaction_date,\n    order_margin_pct,\n    order_total\n  FROM DEMO_DB.SHAKE_SHACK.MKT_CHANNEL_FINANCIAL_MART\n)\nSELECT\n  clv_tier,\n  CASE WHEN clv_tier IN ('PLATINUM', 'GOLD') THEN 'High-Value' ELSE 'Standard' END AS customer_segment,\n  channel_group,\n  order_channel,\n  COUNT(DISTINCT guest_id) AS unique_guests,\n  COUNT(*) AS order_count,\n  ROUND(AVG(order_total), 2) AS avg_order_value,\n  ROUND(SUM(order_total), 2) AS total_revenue,\n  ROUND(AVG(order_margin_pct), 2) AS avg_margin_pct\nFROM __channel_financial\nWHERE\n  transaction_date <= CURRENT_DATE\nGROUP BY\n  clv_tier,\n  customer_segment,\n  channel_group,\n  order_channel\nORDER BY\n  CASE\n    WHEN clv_tier = 'PLATINUM'\n    THEN 1\n    WHEN clv_tier = 'GOLD'\n    THEN 2\n    WHEN clv_tier = 'SILVER'\n    THEN 3\n    WHEN clv_tier = 'BRONZE'\n    THEN 4\n    ELSE 5\n  END,\n  total_revenue DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: eae3cd8a-6f99-424a-ba6f-65fde246c556)\n;",
              "text": "The question is clear and I can answer it with the following SQL.",
              "verified_query_used": true
            },
            "type": "json"
          }
