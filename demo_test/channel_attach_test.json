              "result_set_truncated": false,
              "sql": "WITH all_locations AS (\n    SELECT *\n    FROM SEMANTIC_VIEW(\n        DEMO_DB.SHAKE_SHACK.MKT_MENU_LTO_VIEW\n        METRICS sum_channel_total_txns\n        DIMENSIONS attach_location_market\n        WHERE attach_transaction_date <= CURRENT_DATE\n    )\n),\ntop_20_locations AS (\n    SELECT\n        attach_location_market,\n        sum_channel_total_txns\n    FROM all_locations\n    ORDER BY sum_channel_total_txns DESC NULLS LAST\n    LIMIT 20\n),\nchannel_attach AS (\n    SELECT *\n    FROM SEMANTIC_VIEW(\n        DEMO_DB.SHAKE_SHACK.MKT_MENU_LTO_VIEW\n        METRICS true_channel_attach_rate,\n               sum_lto_txns,\n               sum_channel_total_txns\n        DIMENSIONS lto_item_name,\n                   attach_location_market,\n                   attach_order_channel\n        WHERE (lto_item_name = 'Big Shack' OR lto_item_name = 'Dubai Chocolate Shake')\n          AND (attach_order_channel = 'KIOSK' OR attach_order_channel = 'UBER_EATS' OR attach_order_channel = 'DOORDASH' OR attach_order_channel = 'GRUBHUB')\n          AND attach_transaction_date <= CURRENT_DATE\n    )\n)\nSELECT\n    ca.lto_item_name,\n    ca.attach_location_market,\n    ca.attach_order_channel,\n    CASE\n        WHEN ca.attach_order_channel = 'KIOSK' THEN 'In-Shack Kiosk'\n        ELSE 'Third-Party Delivery'\n    END AS channel_type,\n    ca.true_channel_attach_rate,\n    ca.sum_lto_txns,\n    ca.sum_channel_total_txns,\n    t20.sum_channel_total_txns AS location_total_txns\nFROM channel_attach AS ca\nINNER JOIN top_20_locations AS t20\n    ON ca.attach_location_market = t20.attach_location_market\nORDER BY t20.sum_channel_total_txns DESC NULLS LAST, ca.lto_item_name, ca.attach_order_channel\n -- Generated by Cortex Analyst (request_id: 692c3585-2aed-4a88-bc3c-bd42bf292ef8)\n;",
              "text": "The question is clear and I can answer it with the following SQL."
            },
