              "result_set_truncated": false,
              "sql": "WITH __retention AS (\n  SELECT\n    acquisition_promo,\n    first_visit_date,\n    returned_within_30,\n    days_to_return,\n    first_order_total,\n    second_order_total\n  FROM DEMO_DB.SHAKE_SHACK.MKT_GUEST_RETENTION_COHORT\n)\nSELECT\n  acquisition_promo = 'APP135' AS is_app135_promo,\n  COUNT(*) AS total_acquired,\n  SUM(CASE WHEN returned_within_30 THEN 1 ELSE 0 END) AS returned_30d_count,\n  ROUND(\n    100.0 * SUM(CASE WHEN returned_within_30 THEN 1 ELSE 0 END) / NULLIF(NULLIF(COUNT(*), 0), 0),\n    1\n  ) AS retention_rate,\n  ROUND(AVG(first_order_total), 2) AS avg_first_order_total,\n  ROUND(AVG(second_order_total), 2) AS avg_second_order_total,\n  ROUND(AVG(CASE WHEN returned_within_30 THEN days_to_return END), 1) AS avg_days_to_return_30d,\n  MIN(first_visit_date) AS min_first_visit_date,\n  MAX(first_visit_date) AS max_first_visit_date,\n  COUNT(first_visit_date) AS count_first_visit_date\nFROM __retention\nWHERE\n  first_visit_date >= '2025-10-01'\n  AND first_visit_date <= '2025-12-31'\n  AND first_visit_date <= CURRENT_DATE\nGROUP BY\n  is_app135_promo\nORDER BY\n  is_app135_promo DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: d4454b49-436b-46e1-a91e-0cc05634aa31)\n;",
