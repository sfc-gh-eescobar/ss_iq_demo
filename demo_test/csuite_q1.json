              "result_set_truncated": false,
              "sql": "WITH __channel_financial AS (\n  SELECT\n    order_channel,\n    transaction_date,\n    item_count,\n    order_margin_pct,\n    order_total\n  FROM DEMO_DB.SHAKE_SHACK.MKT_CHANNEL_FINANCIAL_MART\n)\nSELECT\n  CASE WHEN order_channel = 'APP' THEN 'APP' ELSE 'OTHER_CHANNELS' END AS channel_type,\n  order_channel,\n  COUNT(*) AS transaction_count,\n  ROUND(AVG(order_total), 2) AS avg_order_value,\n  ROUND(SUM(order_total), 2) AS total_revenue,\n  ROUND(AVG(order_margin_pct), 2) AS avg_margin_pct,\n  ROUND(AVG(item_count), 2) AS avg_item_count,\n  MIN(transaction_date) AS min_date,\n  MAX(transaction_date) AS max_date,\n  COUNT(transaction_date) AS date_count\nFROM __channel_financial\nWHERE\n  transaction_date >= '2025-10-01'\n  AND transaction_date <= '2025-12-31'\n  AND transaction_date <= CURRENT_DATE\nGROUP BY\n  CASE WHEN order_channel = 'APP' THEN 'APP' ELSE 'OTHER_CHANNELS' END,\n  order_channel\nORDER BY\n  channel_type ASC,\n  avg_order_value DESC NULLS LAST\n -- Generated by Cortex Analyst (request_id: 56baa1e3-8083-4c81-b69b-de3a3ac83646)\n;",
